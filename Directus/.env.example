KEY=replace-with-a-long-random-string
SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@gencolink.com
ADMIN_PASSWORD=change-me-now
PUBLIC_URL=http://localhost:8055
DB_CLIENT=sqlite3
DB_FILENAME=/directus/database/data.db
WEBSOCKETS_ENABLED=false

# send-contact-email Function (func start, default port 7071) - lets the
# "Notify on Contact Submission" Flow work locally without editing it
FLOWS_ENV_ALLOW_LIST=AZURE_FUNCTION_URL,AZURE_FUNCTION_KEY
AZURE_FUNCTION_URL=http://host.docker.internal:7071/api/send-contact-email
AZURE_FUNCTION_KEY=
