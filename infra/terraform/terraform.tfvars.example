# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to Git - it contains secrets (it is gitignored).
#
# Secrets NOT listed here are auto-generated by Terraform (random_password in
# main.tf) and pushed to Key Vault + GitHub Secrets: the Directus admin
# password, admin token, JWT secret, app secret, and the SQL admin password.
# You never set those by hand.

# Existing resource group (Terraform reads it; it must already exist)
resource_group_name = "gencolink"

project_name = "gencolink"
environment  = "prod"

# Primary location, with optional per-service overrides (uncomment to change)
primary_location = "eastus2"
# directus_location  = "eastus2"
# frontend_location  = "eastus2"   # SWA regions: centralus, eastus2, westus2, westeurope, eastasia
# storage_location   = "eastus2"
# keyvault_location  = "eastus2"
app_service_location = "westus2" # Keep in the same region as SQL Server to avoid cross-region boot latency

# Azure SQL Server
sql_location       = "westus2"
sql_admin_username = "sqladmin"
sql_database_name  = "directus"
# sql_admin_password: leave unset to let Terraform auto-generate and manage it.
# Only set it to pin a specific password.

# GitHub integration (Static Web App + Actions secrets sync)
# PAT needs 'repo' scope (classic) or Actions read/write (fine-grained).
# Prefer supplying this via the GITHUB_TOKEN env var instead of this file.
github_repo_token = "YOUR_GITHUB_PAT_HERE"
github_repo_url   = "https://github.com/yourname/gencolink"
github_owner      = "yourname"
github_repository = "gencolink"
github_branch     = "master"

# Directus (only the admin email is user-supplied)
directus_admin_email       = "admin@gencolink.com"
directus_refresh_token_ttl = 7

# Azure Communication Services - managed-identity auth (no connection string / key).
# The Function App's identity is granted "Communication and Email Service Owner"
# on the ACS resource; only the non-secret endpoint URL and resource name go here.
azure_communication_email_domain = "https://YOUR_RESOURCE.<region>.communication.azure.com/"
acs_resource_name                = "YOUR_ACS_RESOURCE_NAME"
from_email_address               = "DoNotReply@yourdomain.com" # must match a verified ACS sender username
contact_recipient_email          = "contact@yourdomain.com"

# App Service Plan (hosts Directus + the Functions app)
enable_app_service = true
app_service_sku    = "B1" # Minimum viable tier; F1/Free is unusable for Directus

# Tags
tags = {
  Project     = "Gencolink"
  Environment = "Production"
  ManagedBy   = "Terraform"
  Owner       = "Your Name"
}
